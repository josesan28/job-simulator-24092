services:
  app:
    build: ./api
    ports:
      - "8080:3000"
    env_file:
      - ./api/.env
    depends_on:
      db:
        condition: service_healthy

  db:
    image: postgres:16-alpine
    environment:
      POSTGRES_DB: jobsimulator
      POSTGRES_USER: user
      POSTGRES_PASSWORD: password
    volumes:
      - ./api/init.sql:/docker-entrypoint-initdb.d/init.sql
      - pgdata:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U user -d jobsimulator"]
      interval: 5s
      timeout: 5s
      retries: 5

  frontend:
    build: ./frontend
    ports:
      - "8088:80"

volumes:
  pgdata: